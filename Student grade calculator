# Function to calculate grade and comment
def calculate_grade(average):
    """Calculate grade based on average marks"""
    if average >= 90:
        return 'A', "Excellent! Keep up the great work!"
    elif average >= 80:
        return 'B', "Very Good! You're doing well."
    elif average >= 70:
        return 'C', "Good. Room for improvement."
    elif average >= 60:
        return 'D', "Needs Improvement. Please study more."
    else:
        return 'F', "Failed. Please seek help from teacher."


# Function to get valid number within range
def get_valid_number(prompt, min_val=0, max_val=100):
    """Get a valid number within specified range"""
    while True:
        try:
            value = float(input(prompt))
            if value < min_val or value > max_val:
                print(f"Please enter marks between {min_val} and {max_val}.")
            else:
                return value
        except ValueError:
            print("Invalid input! Please enter a numeric value.")


# Main Program
print("=" * 50)
print("        STUDENT GRADE CALCULATOR")
print("=" * 50)

# Validate number of students
while True:
    try:
        num_students = int(input("Enter number of students: "))
        if num_students <= 0:
            print("Please enter a positive number.")
        else:
            break
    except ValueError:
        print("Invalid input! Please enter a number.")

# Lists to store data
student_names = []
student_averages = []
student_grades = []
student_comments = []

# Collect student data
for i in range(num_students):
    print(f"\nEntering details for Student {i+1}")
    
    name = input("Enter student name: ")
    
    mark1 = get_valid_number("Enter marks for Subject 1: ")
    mark2 = get_valid_number("Enter marks for Subject 2: ")
    mark3 = get_valid_number("Enter marks for Subject 3: ")
    
    average = (mark1 + mark2 + mark3) / 3
    grade, comment = calculate_grade(average)
    
    student_names.append(name)
    student_averages.append(average)
    student_grades.append(grade)
    student_comments.append(comment)

# Calculate class statistics
class_average = sum(student_averages) / len(student_averages)
highest = max(student_averages)
lowest = min(student_averages)

# Display Results
print("\n" + "=" * 70)
print("                     FINAL RESULTS")
print("=" * 70)

print(f"{'Name':<15}{'Average':<10}{'Grade':<10}{'Comment'}")
print("-" * 70)

for i in range(num_students):
    print(f"{student_names[i]:<15}{student_averages[i]:<10.2f}{student_grades[i]:<10}{student_comments[i]}")

print("-" * 70)
print(f"Class Average: {class_average:.2f}")
print(f"Highest Average: {highest:.2f}")
print(f"Lowest Average: {lowest:.2f}")

# Search Feature
while True:
    choice = input("\nDo you want to search for a student? (yes/no): ").lower()
    if choice == "yes":
        search_name = input("Enter student name to search: ")
        if search_name in student_names:
            index = student_names.index(search_name)
            print("\nStudent Found!")
            print(f"Name: {student_names[index]}")
            print(f"Average: {student_averages[index]:.2f}")
            print(f"Grade: {student_grades[index]}")
            print(f"Comment: {student_comments[index]}")
        else:
            print("Student not found.")
    elif choice == "no":
        break
    else:
        print("Please enter yes or no.")

print("\nProgram completed successfully!")
print("=" * 50)
