# -----------------------------------------------
# FUNCTION WITH TYPE HINTS
# -----------------------------------------------
@timing_decorator
def add_numbers(a: int, b: int) -> int:
    """
    Adds two integers and returns the result.

    Parameters:
    a (int): First number
    b (int): Second number

    Returns:
    int: Sum of a and b
    """
    return a + b


