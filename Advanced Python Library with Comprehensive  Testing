import time
from functools import wraps


# -----------------------------------------------
# DECORATOR: Measures execution time of functions
# -----------------------------------------------
def timing_decorator(func):
    """
    This decorator calculates how long a function takes to execute.
    It wraps the original function and prints execution time.
    """

    @wraps(func)  # Preserves original function metadata
    def wrapper(*args, **kwargs):
        start_time = time.time()   # Record start time

        result = func(*args, **kwargs)  # Execute original function

        end_time = time.time()     # Record end time

        # Calculate and display execution time
        print(f"[INFO] '{func.__name__}' executed in {end_time - start_time:.4f} seconds")

        return result

    return wrapper


# -----------------------------------------------
# GENERATOR: Efficient number generator
# -----------------------------------------------
def number_generator(limit: int):
    """
    Generates numbers from 0 to (limit - 1)
    using 'yield' for memory efficiency.
    """
    for i in range(limit):
        yield i   # Returns one value at a time


# -----------------------------------------------
# CONTEXT MANAGER: Handles file operations safely
# -----------------------------------------------
class FileManager:
    """
    Custom context manager for file handling.
    Ensures file is properly opened and closed.
    """

    def __init__(self, filename: str, mode: str):
        self.filename = filename
        self.mode = mode

    def __enter__(self):
        """
        Automatically called when entering 'with' block.
        Opens the file.
        """
        print("[INFO] Opening file...")
        self.file = open(self.filename, self.mode)
        return self.file

    def __exit__(self, exc_type, exc_value, traceback):
        """
        Automatically called when exiting 'with' block.
        Closes the file safely.
        """
        print("[INFO] Closing file...")
        self.file.close()


